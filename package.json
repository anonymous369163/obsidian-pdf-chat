{
  "name": "pdf-chat",
  "version": "0.8.3",
  "private": true,
  "description": "Chat with selected text and PDFs in Obsidian using an OpenAI-compatible API.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "scan:secrets": "node scripts/secret-scan.js",
    "verify:release": "node scripts/verify-release.js",
    "verify": "node scripts/verify.js",
    "deploy:local": "npm run verify && node scripts/deploy-local.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.0",
    "typescript": "^5.8.0"
  }
}
